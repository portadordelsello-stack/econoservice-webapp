rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isGlobalAdminEmail() {
      return isAuthenticated() && 
             'email' in request.auth.token &&
             request.auth.token.email.lower() == 'juanpacheco@playcode.com.ar';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isUserActive() {
      return !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
             !('activo' in getUserData()) ||
             getUserData().activo == true ||
             getUserData().activo == 'true';
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 'rol' in getUserData()
             ? getUserData().rol.lower()
             : 'tecnico';
    }

    // Unified helper that reads the document at most once and handles role-checking safely.
    function hasAnyRole(roles) {
      return isAuthenticated() && (
        isGlobalAdminEmail() || (
          isUserActive() && (
            getUserRole() in roles ||
            getUserRole() == 'superadmin' ||
            getUserRole() == 'admin'
          )
        )
      );
    }

    // Rules for collections
    
    // 1. Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation of own profile on first register
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow updates to own profile (except rol and activo, unless they are admin)
      allow update: if isAuthenticated() && (
        hasAnyRole(['superadmin', 'admin']) || 
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'activo']))
      );
      allow delete: if hasAnyRole(['superadmin', 'admin']);
    }
    
    // 2. Clientes
    match /clientes/{clienteId} {
      allow get: if true;
      allow list, write: if isAuthenticated();
    }
    
    // 3. Tecnicos
    match /tecnicos/{tecnicoId} {
      allow read: if isAuthenticated();
      allow write: if hasAnyRole(['superadmin', 'admin', 'tecnico']);
    }
    
    // 4. Equipos
    match /equipos/{equipoId} {
      allow get: if true;
      allow list, write: if isAuthenticated();
    }
    
    // 5. Servicios
    match /servicios/{servicioId} {
      allow get: if true;
      allow list: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if hasAnyRole(['superadmin', 'admin']);
      
      // Historial Subcollection
      match /historial/{historialId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if hasAnyRole(['superadmin', 'admin']);
      }
    }
    
    // 6. Presupuestos
    match /presupuestos/{presupuestoId} {
      allow read, write: if isAuthenticated();
      
      // Items Subcollection
      match /items/{itemId} {
        allow read, write: if isAuthenticated();
      }
    }
    
    // 7. Gastos
    match /gastos/{gastoId} {
      allow read: if hasAnyRole(['superadmin', 'admin', 'administracion']);
      allow write: if hasAnyRole(['superadmin', 'admin']);
    }
    
    // 8. Config
    match /config/{configId} {
      allow read: if configId == 'branding' || isAuthenticated();
      allow write: if (configId == 'branding' && hasAnyRole(['superadmin'])) || (configId != 'branding' && hasAnyRole(['superadmin', 'admin']));
    }

    // 9. Tracking de Envíos (Public read, driver write)
    match /tracking_envios/{servicioId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // 10. Proveedores
    match /proveedores/{proveedorId} {
      allow read, write: if isAuthenticated();
    }

    // 11. Stock (Inventario)
    match /stock/{stockId} {
      allow read, write: if isAuthenticated();
    }

    // 12. Notifications
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
