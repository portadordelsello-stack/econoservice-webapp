rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isGlobalAdminEmail() {
      return isAuthenticated() && 
             'email' in request.auth.token &&
             request.auth.token.email.lower() == 'juanpacheco@playcode.com.ar';
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol;
    }

    function isUserActive() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.activo == true;
    }

    // Unified helper that reads the document at most once and handles role-checking safely.
    // It short-circuits for the global admin so no document fetch is required for them.
    function hasAnyRole(roles) {
      return isAuthenticated() && (
        isGlobalAdminEmail() || (
          isUserActive() && getUserRole() in roles
        )
      );
    }

    // Rules for collections
    
    // 1. Users
    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow creation of own profile on first register
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Allow updates to own profile (except rol and activo, unless they are admin)
      allow update: if isAuthenticated() && (
        hasAnyRole(['superadmin', 'admin']) || 
        (request.auth.uid == userId && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'activo']))
      );
      allow delete: if hasAnyRole(['superadmin', 'admin']);
    }
    
    // 2. Clientes
    match /clientes/{clienteId} {
      allow get: if true;
      allow list: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
      allow write: if hasAnyRole(['superadmin', 'admin', 'logistica', 'recepcion']);
    }
    
    // 3. Tecnicos
    match /tecnicos/{tecnicoId} {
      allow read: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
      allow write: if hasAnyRole(['superadmin', 'admin']);
    }
    
    // 4. Equipos
    match /equipos/{equipoId} {
      allow get: if true;
      allow list: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
      allow write: if hasAnyRole(['superadmin', 'admin', 'logistica', 'recepcion']);
    }
    
    // 5. Servicios
    match /servicios/{servicioId} {
      allow get: if true;
      allow list: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
      allow create: if hasAnyRole(['superadmin', 'admin', 'logistica', 'recepcion']);
      allow delete: if hasAnyRole(['superadmin', 'admin']);
      allow update: if hasAnyRole(['superadmin', 'admin', 'logistica', 'recepcion']) || (
        hasAnyRole(['tecnico']) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'diagnostico', 'estado', 'repuestosComprar', 'repuestosComprados', 'updatedAt'
        ])
      );
      
      // Historial Subcollection
      match /historial/{historialId} {
        allow read: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
        allow create: if hasAnyRole(['superadmin', 'admin', 'logistica', 'recepcion', 'tecnico']);
        allow update, delete: if hasAnyRole(['superadmin', 'admin']);
      }
    }
    
    // 6. Presupuestos
    match /presupuestos/{presupuestoId} {
      allow read: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
      allow write: if hasAnyRole(['superadmin', 'admin', 'recepcion', 'logistica']);
      
      // Items Subcollection
      match /items/{itemId} {
        allow read: if hasAnyRole(['superadmin', 'admin', 'administracion', 'tecnico', 'logistica', 'recepcion', 'consulta']);
        allow write: if hasAnyRole(['superadmin', 'admin', 'recepcion', 'logistica']);
      }
    }
    
    // 7. Gastos
    match /gastos/{gastoId} {
      allow read: if hasAnyRole(['superadmin', 'admin', 'administracion']);
      allow write: if hasAnyRole(['superadmin', 'admin']);
    }
    
    // 8. Config
    match /config/{configId} {
      allow read: if configId == 'branding' || isAuthenticated();
      allow write: if (configId == 'branding' && hasAnyRole(['superadmin'])) || (configId != 'branding' && hasAnyRole(['superadmin', 'admin']));
    }

    // 9. Tracking de Envíos (Public read, driver write)
    match /tracking_envios/{servicioId} {
      allow read: if true;
      allow write: if hasAnyRole(['superadmin', 'admin', 'logistica']);
    }

    // 10. Proveedores
    match /proveedores/{proveedorId} {
      allow read, write: if isAuthenticated();
    }

    // 11. Stock (Inventario)
    match /stock/{stockId} {
      allow read, write: if isAuthenticated();
    }

    // 12. Notifications
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
  }
}
